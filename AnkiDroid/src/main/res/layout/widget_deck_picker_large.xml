            <TextView
                android:id="@+id/deck5Due"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/anki_foreground_icon_color_0"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/deck5Learn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/flag_reviewer_green"
                android:textSize="18sp" />
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>
