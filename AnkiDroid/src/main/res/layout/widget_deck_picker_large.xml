                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/flag_reviewer_green"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/deck4Layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceVariant"
            android:clickable="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/deck4Name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:paddingBottom="4dp"
                android:paddingStart="15dp"
                android:paddingTop="4dp"
                android:text="@string/deck4"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/deck4New"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/flag_reviewer_blue"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/deck4Due"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
