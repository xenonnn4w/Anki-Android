<RelativeLayout
    android:id="@+id/widget_deck_picker"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:clickable="true"
    android:focusable="false"
    android:theme="@style/Theme.Material3.DynamicColors.DayNight">

    <ImageButton
        android:id="@+id/widget_app_open_button"
        android:layout_width="37dp"
        android:layout_height="37dp"
        android:layout_gravity="center"
        android:background="?attr/colorSurface"
        android:clickable="false"
        android:cropToPadding="false"
        android:focusable="false"
        android:paddingBottom="3dp"
        android:paddingEnd="5dp"
        android:paddingTop="10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_star_144dp" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="1dp"
        android:layout_toEndOf="@id/widget_app_open_button"
        android:paddingTop="4dp"
        android:text="@string/DeckPickerWidgetLabel"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="23sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/deckCollection"
        android:layout_width="match_parent"
        android:layout_height="702dp"
        android:layout_marginTop="38dp"
        android:background="?attr/colorSurface"
        android:orientation="vertical"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/deck1Layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceVariant"
            android:clickable="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/deck1Name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:paddingBottom="4dp"
                android:paddingStart="15dp"
                android:paddingTop="4dp"
                android:text="@string/deck1"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/deck1New"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/flag_reviewer_blue"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/deck1Due"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/anki_foreground_icon_color_0"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/deck1Learn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/flag_reviewer_green"
                android:textSize="20sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/deck2Layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurfaceVariant"
            android:clickable="true"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/deck2Name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:paddingBottom="4dp"
                android:paddingStart="15dp"
                android:paddingTop="4dp"
                android:text="@string/deck2"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/deck2New"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/flag_reviewer_blue"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/deck2Due"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingEnd="5dp"
                android:text=""
                tools:text="50"
                android:textColor="@color/anki_foreground_icon_color_0"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/deck2Learn"
                android:layout_width="0dp"
